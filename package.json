{
  "name": "js65",
  "version": "0.0.0",
  "main": "target/debug/js/patch.js",
  "scripts": {
    "cli-watch": "bun --watch --inspect ./integrations/bun.ts",
    "exe": "bun build --compile --minify --sourcemap --bytecode ./integrations/bun.ts --outfile ./build/js65",
    "lib": "bun build --entrypoints ./src/libassembler.ts --sourcemap=linked --outdir ./build",
    "quickjs-bundle": "bun build ./integrations/quickjs.ts --outfile ./build/quickjs.bundle.js --format esm --target node --external qjs:std --external qjs:os",
    "quickjs-exe": "bun run quickjs-bundle && qjs -c ./build/quickjs.bundle.js -o ./build/js65-qjs",
    "hermes-exe": "bun run integrations/hermes/hermes-build.ts",
    "build": "bun run --no-exit-on-error --parallel exe hermes-exe quickjs-exe",
    "bench": "bun run build && bun run bench/bench.ts"
  },
  "bin": {
    "js65": "target/release/bin/js65"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsnesx/js65.git"
  },
  "author": "Stephen Hicks",
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/jsnesx/js65/issues"
  },
  "homepage": "https://github.com/jsnesx/js65#readme",
  "devDependencies": {
    "@types/bun": "^1.2.9",
    "@types/node": "^25.9.3",
    "typescript": "^5.8.3",
    "typescript-language-server": "^2.3.0"
  },
  "description": "",
  "dependencies": {}
}
