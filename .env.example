# Static Hermes (shermes) toolchain locations for `bun run hermes-exe`.
# Copy to `.env.local` (git-ignored) and adjust for your machine. The build
# script (integrations/hermes/hermes-build.ts) reads these; CI sets them directly.

# Root of the Hermes checkout and its build directory.
# HERMES_SRC defaults to a sibling checkout (../hermes).
#HERMES_SRC=C:/dev/hermes
#HERMES_BUILD=C:/dev/hermes/build

# Per-config output subdir. Set to "Release" for an MSVC multi-config build,
# leave empty for a Ninja/Make single-config build. Defaults: Release on
# Windows, empty elsewhere.
#HERMES_CONFIG=Release

# Compilers. Either point LLVM_BIN at the LLVM bin dir, or give full paths in
# CLANG / CLANGXX. Defaults to `clang` / `clang++` from PATH.
#LLVM_BIN=C:/Users/you/scoop/apps/llvm/current/bin
#CLANG=
#CLANGXX=

# Optional explicit overrides (otherwise derived from the above):
#SHERMES=C:/dev/hermes/build/bin/Release/shermes.exe
#HERMES_BOOST_CONTEXT_DIR=
